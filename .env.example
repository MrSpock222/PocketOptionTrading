# Telegram Bot Token (vom @BotFather)
TELEGRAM_BOT_TOKEN="HIER_DEIN_TOKEN"

# PocketOption Session IDs (aus Browser-Cookies)
POCKET_OPTION_SSID_DEMO="HIER_DEMO_SSID"
POCKET_OPTION_SSID_REAL="HIER_REAL_SSID"

# NemoClaw Proxy (unser eigener OpenAI-kompatibler Proxy)
# Der Proxy leitet an OpenClaw CLI weiter (Gateway chatCompletions ist gesperrt)
NEMOCLAW_URL="http://localhost:18790"
NEMOCLAW_TOKEN="DEIN_PROXY_TOKEN_HIER"

# NemoClaw Proxy Konfiguration (für nemoclaw_proxy.py)
NEMOCLAW_PROXY_PORT="18790"
NEMOCLAW_PROXY_TOKEN="DEIN_PROXY_TOKEN_HIER"
NEMOCLAW_AGENT="main"
NEMOCLAW_SESSION_ID="trading-bot"
NEMOCLAW_TIMEOUT="120"

# Fallback: Direkter Gateway (falls chatCompletions doch aktiviert wird)
NEMOCLAW_GATEWAY_URL="http://localhost:18789"
# NEMOCLAW_GATEWAY_TOKEN="DEIN_GATEWAY_TOKEN"
